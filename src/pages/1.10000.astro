---
// Importa il layout di base (se ne hai uno, altrimenti puoi ometterlo)
// import BaseLayout from '../layouts/BaseLayout.astro';
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Scala 1:10000 - Landing Page</title>
    <style>
      body {
        background-color: #f8f8f8; /* Sfondo bianco sporco */
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh; /* Occupa l'intera altezza della finestra */
        font-family: sans-serif; /* Font temporaneo */
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 2rem;
        /* Aggiungi qui lo stile per il font scelto in seguito */
      }

      img {
        width: 50%; /* Regola la larghezza dell'immagine */
        max-width: 600px; /* Imposta una larghezza massima */
        height: auto;
        opacity: 0; /* Inizialmente trasparente */
        animation: fade-in 2s ease-in-out forwards; /* Effetto fade-in */
      }

      @keyframes fade-in {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      button {
        background-color: #333; /* Colore del bottone */
        color: white;
        padding: 1rem 2rem;
        border: none;
        border-radius: 5px;
        font-size: 1.2rem;
        cursor: pointer;
        margin-top: 2rem;
        transition: background-color 0.3s ease;
      }

      button:hover {
        background-color: #555; /* Colore al passaggio del mouse */
      }
    </style>
  </head>
  <body>
    <h1>Scala 1:10000</h1>
    <img src="/percorso/della/tua/foto.jpg" alt="Foto centrale del progetto" />
    <button>Inizia</button>
  </body>
</html>