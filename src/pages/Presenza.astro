---
// Qui potresti definire i dati delle 4 foto in futuro
const fotoPresenza = [
  { src: '/io/foto/P1.jpg', alt: 'P/1', desc: 'Litli-Hrútur, Fagradalsfjall - 2023', tag: '[00°36’57”N 00°59’34”W]'  },
  { src: '/io/foto/P2.jpg', alt: 'P/2', desc: 'Húnaflói / Steingrímsfjörðu - 2020', tag: '[63°00’57”N 19°59’34”W]'  },
  { src: '/io/foto/P3.jpg', alt: 'P/3', desc: 'Seljalandsfoss - 2021', tag: '[63°36’57”N 19°59’34”W]' },
  { src: '/io/foto/P4.jpg', alt: 'P/4', desc: 'Fjallsarlon - 2020' ,tag: '[63°36’57”N 19°59’34”W]' },
];
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <title>Presenza - Scala 1:10000</title>
    
    <style>
      @font-face {
          font-family: 'Jester';
          src: url('/io/fonts/JetBrainsMono-VariableFont_wght.ttf') format('truetype');
          font-weight: normal;
          font-style: normal;
          font-display: swap;
        }
      @font-face {
          font-family: 'Inter';
          src: url('/io/fonts/Inter-VariableFont_opsz,wght.ttf') format('truetype');
          font-weight: normal;
          font-style: normal;
          font-display: swap;
        }
  

      body {
        background-color: #929292;
        margin: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 20px;
        min-height: 100vh;
        font-family: sans-serif;
      }

      h1 {
        font-family: 'Jester', serif;
        font-size: 3rem;
        margin-bottom: 40px;
        color: #1a1a1a;
      }

      /* Griglia 2x2 */
      .grid-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 800px;
        width: 100%;
      }

      .photo-wrapper {
        position: relative;
        overflow: hidden;
        
        background-color: #eee;
      }

      .photo-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.2s ease-in-out;
      }

      /* Effetto Vibrante e Zoom al passaggio del mouse */
      .photo-wrapper:hover img {
        transform: scale(1.01) rotate(0.2deg); /* Leggera rotazione per l'effetto "vibrazione" */
      }

      /* Didascalia a comparsa */
      .caption {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        background: #ffd700;
        color: #252525;
        padding: 10px;
        font-family: 'Jester';
        font-size: 0.8rem;
        text-align: center;
        opacity: 0;
        transform: translateY(100%);
        transition: all 0.3s ease;
      }

      .photo-wrapper:hover .caption {
        opacity: 1;
        transform: translateY(0);
      }

      .description-area {
        margin-top: 30px;
        max-width: 600px;
        text-align: center;
        font-family: 'Inter', serif;
        line-height: 1.6;
        color: #333;
      }

      /* La linea gialla (riutilizziamo lo stile) */
      .timeline-container {
        margin-top: 60px;
        width: 100%;
        max-width: 600px;
      }

      .timeline-labels {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #666;
      }

      /* Evidenziamo "Presenza" visto che siamo in questa pagina */
      .timeline-labels span:first-child {
        color: #1a1a1a;
        font-weight: bold;
      }

      .timeline-line {
        width: 100%;
        height: 1px;
        background-color: #ffd700;
      }


      /* stile del testo ghost sullo sfondo*/
      .bg-text-style {
        position: fixed;
        top: 80%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'Jester', serif; /* Oppure un font molto bold */
        font-size: 10vw; /* Dimensione enorme basata sulla larghezza dello schermo */
        color: #dddddd49; 
        white-space: nowrap;
        pointer-events: none; /* Importante: il mouse deve "passarci attraverso" */
        z-index: -1;
        transition: opacity 0.5s ease;
        text-transform: uppercase;
      }
      .bg-alt-style {
          position: fixed;
          top: 50%;
          left: 5%; /* Allineato a sinistra con un po' di margine */
          transform: translateY(-50%);
          font-family: 'Jester', serif;
          font-size: 15vw; /* Leggermente più piccolo del tag centrale */
          color: #ffd700; /* Usiamo il giallo spento con trasparenza */
          white-space: nowrap;
          pointer-events: none;
          z-index: -2; /* Ancora più sotto del tag centrale */
          opacity: 0;
          transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
          text-transform: uppercase;
        }


      /* ... altri stili ... */

        .photo-wrapper {
          position: relative;
          overflow: hidden;
          background-color: #eee;
          /* Impostazioni per il Fade iniziale */
          opacity: 0;
          transform: translateY(20px); /* Parte leggermente più in basso */
          animation: fadeEntrata 0.8s ease-out forwards;
        }

        @keyframes fadeEntrata {
          to {
            opacity: 1;
            transform: translateY(0); /* Arriva alla posizione corretta */
          }
        }

        /* Mantieni l'effetto hover che abbiamo creato prima */
        .photo-wrapper:hover img {
          transform: scale(1.03) rotate(0.5deg);
        }


    </style>

  </head>


  <body>
      <div id="bg-text-giant" class="bg-text-style"></div> <!-- blocco ghost per text grigio  sullo sfondo -->
      <div id="bg-alt-left" class="bg-alt-style"></div> <!-- blocco del codice foto sullos fondo-->

    <h1>Presenza</h1>

      <div class="grid-container">
        {fotoPresenza.map((foto, i) => (
          <div 
            class="photo-wrapper" 
            data-tag={foto.tag}
            style={`animation-delay: ${i * 0.2}s;`} 
          >
            <img src={foto.src} alt={foto.alt} />
            <div class="caption">{foto.desc}</div>
          </div>
        ))}
      </div>

      <div class="description-area">
        <p>Presenza è l’illusione di abitare il luogo. <br>
          </p>
      </div>

      <div class="timeline-container">
        <div class="timeline-labels">
          <span>Presenza</span>
          <span>Misura</span>
          <span>Assenza</span>
        </div>
        <div class="timeline-line"></div>
      </div>


<script>
  const giantText = document.getElementById('bg-text-giant')!;
  const altText = document.getElementById('bg-alt-left')!;
  const photoWrappers = document.querySelectorAll('.photo-wrapper');

  photoWrappers.forEach((wrapper) => {
    const img = wrapper.querySelector('img');

    wrapper.addEventListener('mouseenter', () => {
      // 1. Gestione Tag Centrale
      const customTag = wrapper.getAttribute('data-tag'); 
      giantText.textContent = customTag;
      giantText.style.opacity = '1';
      giantText.style.transform = 'translate(-50%, -50%) scale(1.1)';

      // 2. Gestione ALT a Sinistra
      const photoAlt = img.getAttribute('alt');
      altText.textContent = photoAlt;
      altText.style.opacity = '1';
      altText.style.left = '2%'; // Si sposta leggermente verso l'esterno entrando
    });

    wrapper.addEventListener('mouseleave', () => {
      giantText.style.opacity = '0';
      giantText.style.transform = 'translate(-50%, -50%) scale(1)';

      altText.style.opacity = '0';
      altText.style.left = '5%'; // Torna alla posizione originale
    });
  });
</script>



  </body>
</html>